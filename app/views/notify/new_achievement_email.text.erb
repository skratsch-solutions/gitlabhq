<%= sprintf(s_("Achievements|%{namespace_full_path} awarded you the %{achievement_name} achievement!"),
  { namespace_full_path: @achievement.namespace.full_path, achievement_name: @achievement.name }) %>
<% if @user_achievement.award_message.present? %>
  <%= @user_achievement.award_message %>
<% end %>
<%= s_("Achievements|To show this achievement on your profile, accept it: %{url}") % { url: @accept_url } %>
<%= s_("Achievements|If you do not wish to accept, simply ignore this email.") %>
