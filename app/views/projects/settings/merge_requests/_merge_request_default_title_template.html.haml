- form = local_assigns.fetch(:form)

%fieldset.form-group.gl-form-group{ aria: { describedby: :mr_default_title_template_description }, data: { testid: 'mr-default-title-template-fieldset' } }
  = form.label :mr_default_title_template, class: 'gl-block col-form-label' do
    = s_('ProjectSettings|Merge request title template')
    .label-description{ id: :mr_default_title_template_description }
      = s_('ProjectSettings|Set a default title for merge requests.')
  = form.text_field :mr_default_title_template, class: 'form-control gl-form-input', maxlength: Project::MAX_MR_TITLE_TEMPLATE_LENGTH, data: { testid: 'mr-default-title-template-input' }, placeholder: s_('ProjectSettings|Enter a merge request title template')
  %p.form-text.gl-text-subtle
    - default_behavior_link = link_to('', help_page_path('user/project/merge_requests/title_templates.md', anchor: 'default-title-behavior'), target: '_blank', rel: 'noopener noreferrer')
    = safe_format(s_('ProjectSettings|Leave empty to use the %{link_start}default behavior%{link_end}.'), tag_pair(default_behavior_link, :link_start, :link_end))
    = safe_format(s_('ProjectSettings|Maximum %{maxLength} characters.'), maxLength: Project::MAX_MR_TITLE_TEMPLATE_LENGTH)
    - supported_variables_link = link_to('', help_page_path('user/project/merge_requests/title_templates.md', anchor: 'supported-variables'), target: '_blank', rel: 'noopener noreferrer')
    = safe_format(s_('ProjectSettings|%{link_start}Supported variables%{link_end}.'), tag_pair(supported_variables_link, :link_start, :link_end))
