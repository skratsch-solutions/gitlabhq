{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "description": "Import::Offline::Configuration#object_storage_credentials for Google Cloud Storage using a service account key (fog-google JSON API). The uploaded JSON key is flattened into these fields; see Import::Offline::Configuration#flatten_gcs_json_key",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "google_project",
    "type",
    "project_id",
    "private_key",
    "client_email"
  ],
  "definitions": {
    "google_project_id": {
      "type": "string",
      "minLength": 7,
      "maxLength": 30,
      "pattern": "^[a-z][a-z0-9-]{5,28}[a-z0-9]$"
    }
  },
  "properties": {
    "google_project": {
      "$ref": "#/definitions/google_project_id"
    },
    "type": {
      "const": "service_account"
    },
    "project_id": {
      "$ref": "#/definitions/google_project_id"
    },
    "private_key": {
      "type": "string",
      "minLength": 1,
      "maxLength": 16384
    },
    "client_email": {
      "type": "string",
      "minLength": 1,
      "maxLength": 255,
      "pattern": "^[a-zA-Z0-9._%+-]+@[a-zA-Z0-9.-]+\\.gserviceaccount\\.com$"
    }
  }
}
