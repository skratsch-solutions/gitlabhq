{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "required": [
    "image",
    "commands"
  ],
  "additionalProperties": false,
  "properties": {
    "commands": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "image": {
      "type": "string"
    },
    "injectGatewayToken": {
      "type": "boolean"
    },
    "variables": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "id_tokens": {
      "description": "CI builds metadata ID tokens",
      "type": "object",
      "maxProperties": 20,
      "additionalProperties": false,
      "patternProperties": {
        "^[a-zA-Z_][a-zA-Z0-9_]*$": {
          "type": "object",
          "required": [
            "aud"
          ],
          "properties": {
            "aud": {
              "oneOf": [
                {
                  "type": "string"
                },
                {
                  "type": "array",
                  "items": {
                    "type": "string"
                  },
                  "minItems": 1,
                  "uniqueItems": true
                }
              ]
            }
          },
          "additionalProperties": false
        }
      }
    },
    "yaml_definition": {
      "type": "string"
    }
  }
}
