{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "description": "Import::Offline::Configuration#object_storage_credentials for Google Cloud Storage using S3-interoperability HMAC keys (fog-aws backend)",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "google_storage_access_key_id",
    "google_storage_secret_access_key",
    "region"
  ],
  "properties": {
    "google_storage_access_key_id": {
      "type": "string",
      "minLength": 24,
      "maxLength": 61,
      "pattern": "^[A-Za-z0-9]+$"
    },
    "google_storage_secret_access_key": {
      "type": "string",
      "minLength": 40,
      "maxLength": 40,
      "pattern": "^[A-Za-z0-9+/]+=*$"
    },
    "region": {
      "type": "string",
      "minLength": 1,
      "maxLength": 50
    },
    "path_style": {
      "type": "boolean"
    }
  }
}
