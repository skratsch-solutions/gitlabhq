- if code_review_enabled && mr_path
  -# haml-lint:disable InlineJavaScript
  - helpers.content_for :startup_js do
    - javascript_tag nonce: content_security_policy_nonce do
      :plain
        const key = 'code-review-' + '#{j(mr_path)}';
        const stored = localStorage.getItem(key);
        if (stored) {
          const linkedFileCodeReviewId = #{linked_file ? "'#{j(linked_file.code_review_id)}'" : 'null'};
          const ids = JSON.parse(stored);
          ids.forEach(id => {
            if (linkedFileCodeReviewId && id === linkedFileCodeReviewId) return;
            const style = document.createElement('style');
            style.dataset.viewedFileStyle = id;
            style.textContent = `:where(diff-file[data-code-review-id="${CSS.escape(id)}"]) [data-file-body] { display: none; }`;
            document.head.appendChild(style);
          });
        }

= render RapidDiffs::AppComponent.new(@presenter, extra_app_data:) do |c|
  - if empty_state_type
    - c.with_empty_state do
      = render RapidDiffs::MergeRequestEmptyStateComponent.new(merge_request: @presenter.resource, type: empty_state_type)
  - c.with_before_diffs_list do
    %div{ data: { commit_widget: true } }
    - if user_permissions[:can_create_note]
      %button.rd-new-discussion-toggle{ 'aria-label': s_('RapidDiffs|Add comment'), data: { new_discussion_toggle: true, click: 'newDiscussion', testid: 'new_discussion_toggle' }, hidden: true }
        = helpers.sprite_icon('comment', size: 12)
  - c.with_diffs_list do
    = render RapidDiffs::MergeRequestDiffFileComponent.with_collection(c.diff_collection, merge_request: @presenter.resource, parallel_view: c.parallel_view?)

-# Load MR stylesheets after base app stylesheets for easier overrides
- helpers.add_page_specific_style 'page_bundles/merge_request_rapid_diffs'
