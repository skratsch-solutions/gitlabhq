# Edit the fragments in flows/ and flows/deploy/, then run `make flows-bundle`.

load("gitlab_functions", gitlab_functions_run = "run")

def gl_run(function, inputs):
    return gather(gitlab_functions_run(function = function, inputs = inputs))

def _require(kwargs, name):
    if name not in kwargs:
        fail("missing required kwarg: %s" % name)
    return kwargs[name]

_SYNC_POLL_INTERVAL = 5 * time.second
_SYNC_MAX_POLLS = 60

_ROLLOUT_POLL_INTERVAL = 30 * time.second
_ROLLOUT_MAX_POLLS = 20

def _dig(value, *keys):
    for key in keys:
        if type(value) != "dict" or key not in value:
            return None
        value = value[key]
    return value

def _pin_images(files, services):
    return gl_run("builtin://manifest.pin_images", {
        "files": files,
        "services": services,
    })["actions"]

def _read_manifests(host, project, branch, path):
    return gl_run("builtin://gitlab_project.read_files", {
        "project": project,
        "ref": branch,
        "path": path,
        "host": host,
    })["files"]

def _commit_manifests(host, project, branch, message, actions):
    return gl_run("builtin://gitlab_project.commit", {
        "project": project,
        "branch": branch,
        "host": host,
        "message": message,
        "actions": actions,
    })["sha"]

def _argo_sync(cluster_agent_id, app_env, revision):
    synced = gl_run("builtin://argo.sync", {
        "agent_id": cluster_agent_id,
        "namespace": app_env["namespace"],
        "application": app_env["application"],
        "revision": revision,
    })
    print("argo-rollout-deploy: synced", app_env["application"], "to", revision,
          "(resource_version", synced["resource_version"], ")")

def _app_sync_state(resource, revision):
    op_phase = _dig(resource, "status", "operationState", "phase")
    synced_revision = _dig(resource, "status", "operationState", "syncResult", "revision")
    detail = "operation phase=%s revision=%s" % (op_phase, synced_revision)

    requested = _dig(resource, "status", "operationState", "operation", "sync", "revision")
    if op_phase == "Failed" or op_phase == "Error":
        if requested == revision:
            return "failed", "operation phase=%s: %s" % (op_phase, _dig(resource, "status", "operationState", "message"))

    if op_phase == "Succeeded" and synced_revision == revision:
        return "synced", detail
    return None, detail

def _wait_argocd_synced(cluster_agent_id, app_env, revision):
    app = app_env["application"]
    namespace = app_env["namespace"]
    detail = None
    for _ in range(_SYNC_MAX_POLLS):
        read_back = gl_run("builtin://k8s.get", {
            "agent_id": cluster_agent_id,
            "api_version": "argoproj.io/v1alpha1",
            "kind": "Application",
            "namespace": namespace,
            "name": app,
        })
        resource = read_back["resource"]
        state, detail = _app_sync_state(resource, revision)
        if state == "failed":
            fail("argo-rollout-deploy: Application %s/%s sync failed: %s" % (namespace, app, detail))
        if state == "synced":
            print("argo-rollout-deploy: Application", app, "synced to", revision)
            return resource
        sleep(_SYNC_POLL_INTERVAL)

    fail("argo-rollout-deploy: Application %s/%s did not sync to %s within %d polls; %s" %
         (namespace, app, revision, _SYNC_MAX_POLLS, detail))

def _detect_rollout(app_resource):
    resources = _dig(app_resource, "status", "resources")
    if type(resources) != "list":
        return None
    for res in resources:
        if _dig(res, "group") == "argoproj.io" and _dig(res, "kind") == "Rollout":
            ns = _dig(res, "namespace")
            name = _dig(res, "name")
            if ns == None or name == None:
                continue
            return {"namespace": ns, "name": name}
    return None

def _rollout_state(resource):
    phase = _dig(resource, "status", "phase")
    detail = "phase=%s" % phase

    gen = _dig(resource, "metadata", "generation")
    observed = _dig(resource, "status", "observedGeneration")
    if gen == None or observed == None or str(gen) != str(observed):
        return None, detail

    if phase == "Degraded" or _dig(resource, "status", "abort"):
        return "degraded", "phase=%s message=%s" % (phase, _dig(resource, "status", "message"))

    if phase == "Paused" and _dig(resource, "status", "pauseConditions"):
        return "paused", detail

    if phase != "Healthy":
        return None, detail
    stable = _dig(resource, "status", "stableRS")
    if stable == None or stable != _dig(resource, "status", "currentPodHash"):
        return None, detail
    desired = _dig(resource, "spec", "replicas")
    if desired == None:
        desired = 1
    if _dig(resource, "status", "updatedReplicas") != desired:
        return None, detail
    if _dig(resource, "status", "availableReplicas") != desired:
        return None, detail

    steps = _dig(resource, "spec", "strategy", "canary", "steps")
    if steps != None and _dig(resource, "status", "currentStepIndex") != len(steps):
        return None, detail

    return "complete", detail

def _wait_for_rollout(cluster_agent_id, namespace, name):
    detail = None
    for i in range(_ROLLOUT_MAX_POLLS):
        if i > 0:
            sleep(_ROLLOUT_POLL_INTERVAL)
        read_back = gl_run("builtin://k8s.get", {
            "agent_id": cluster_agent_id,
            "api_version": "argoproj.io/v1alpha1",
            "kind": "Rollout",
            "namespace": namespace,
            "name": name,
        })
        resource = read_back["resource"]
        state, detail = _rollout_state(resource)
        if state == "degraded":
            fail("argo-rollout-deploy: Rollout %s/%s degraded: %s" % (namespace, name, detail))
        if state == "complete":
            print("argo-rollout-deploy: Rollout", name, "complete (fully rolled out + Healthy)")
            return
        if state == "paused":
            print("argo-rollout-deploy: Rollout", name, "paused at a gate (awaiting promotion)")
            return

    fail("argo-rollout-deploy: Rollout %s/%s did not reach a terminal state within %d polls; %s" %
         (namespace, name, _ROLLOUT_MAX_POLLS, detail))

def _deploy_rolling(app_env, service, cluster_agent_id):
    repo = app_env["manifest_repository"]
    host = repo["host"]
    project = repo["project"]
    branch = repo["branch"]
    path = repo["manifests_path"]

    files = _read_manifests(host, project, branch, path)

    actions = _pin_images(files, [service])

    images = [
        artifact["source"]["image"] + ":" + artifact["version"]
        for artifact in service["artifacts"]
    ]

    sha = _commit_manifests(host, project, branch, "Deploy " + ", ".join(images), actions)
    print("argo-rollout-deploy: committed", sha, "to", project, branch, "->", path)

    _argo_sync(cluster_agent_id, app_env, sha)
    app_resource = _wait_argocd_synced(cluster_agent_id, app_env, sha)

    rollout = _detect_rollout(app_resource)
    if rollout == None:
        print("argo-rollout-deploy: Application", app_env["application"],
              "manages no Rollout; nothing to wait for")
    else:
        _wait_for_rollout(cluster_agent_id, rollout["namespace"], rollout["name"])

def main(w, *args, **kwargs):
    flow_definition = _require(kwargs, "flow_definition")
    environments = _require(kwargs, "environments")
    version_set = _require(kwargs, "version_set")

    service_envs = flow_definition["environments"]

    versions = {service["name"]: service for service in version_set["services"]}

    for stage in flow_definition["stages"]:
        for step in stage["steps"]:
            env_id = str(step["environment"])
            cluster_agent_id = str(environments[env_id]["cluster_agent_id"])
            env_services = service_envs[env_id]["services"]
            step_type = step["type"]
            if step_type == "gitlab.cd.argo_rollouts.deploy_rolling":
                for target in step["services"]:
                    name = target["name"]
                    _deploy_rolling(env_services[name], versions[name], cluster_agent_id)
            else:
                fail("unsupported step type: %s" % step_type)
